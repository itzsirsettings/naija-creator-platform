# Vercel production environment (Next.js) — same-origin proxy setup.
# Do not commit real values. Set these in Vercel project variables.

NEXT_PUBLIC_DEMO_FALLBACK=false

# Recommended: leave NEXT_PUBLIC_API_URL blank so the browser uses the same-origin
# "/api" proxy, and set BACKEND_URL to the API origin. next.config.mjs rewrites
# /api/* to BACKEND_URL server-side (no CORS, first-party cookies).
# Alternatively, point NEXT_PUBLIC_API_URL directly at the HTTPS API ending in /api
# (requires CORS on the API for this origin).
NEXT_PUBLIC_API_URL=
BACKEND_URL=https://<your-railway-api>.up.railway.app

# Frontend Sentry DSN (public by design). Leave blank to disable error tracking.
NEXT_PUBLIC_SENTRY_DSN=https://<public-key>@oXXXX.ingest.<region>.sentry.io/<project-id>
