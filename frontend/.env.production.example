# Vercel production environment (Next.js).
# Do not commit real values. Set these in Vercel project variables.

NEXT_PUBLIC_DEMO_FALLBACK=false
# Live API base ending in /api, OR leave blank and set BACKEND_URL for the rewrite.
NEXT_PUBLIC_API_URL=https://api.tehilla.work/api
BACKEND_URL=https://api.tehilla.work
NEXT_PUBLIC_SENTRY_DSN=https://<public-key>@sentry.io/<project-id>
