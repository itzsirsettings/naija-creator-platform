{
  "name": "tehilla-backend",
  "version": "2.0.0",
  "description": "Tehilla platform backend API — Fastify + TypeScript",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "npx prisma migrate deploy --schema src/prisma/schema.prisma && node dist/app.js",
    "worker:payments": "tsx src/workers/payment.worker.ts",
    "db:migrate": "npx prisma migrate dev --schema src/prisma/schema.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema src/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema src/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema src/prisma/schema.prisma",
    "db:seed:admin": "tsx src/prisma/seedAdmin.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/websocket": "^11.2.0",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.56.0",
    "@upstash/redis": "^1.34.8",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.21",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
