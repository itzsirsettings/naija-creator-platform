{
  "name": "tehilla-backend",
  "version": "1.0.0",
  "description": "Tehilla platform backend API",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "infra:up": "docker compose -f ../docker-compose.yml up -d postgres redis",
    "infra:down": "docker compose -f ../docker-compose.yml down",
    "infra:logs": "docker compose -f ../docker-compose.yml logs -f postgres redis",
    "db:migrate": "npx prisma migrate dev --schema src/prisma/schema.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema src/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema src/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema src/prisma/schema.prisma",
    "db:seed:demo": "node src/prisma/seed.js",
    "db:seed:admin": "node src/prisma/seedAdmin.js",
    "db:seed": "npm run db:seed:demo",
    "readiness:env": "node src/scripts/check-production-env.js",
    "readiness:db": "npx prisma validate --schema src/prisma/schema.prisma && npx prisma migrate status --schema src/prisma/schema.prisma",
    "db:backup:win": "pg_dump \"%DATABASE_URL%\" > tehilla-backup.sql",
    "db:backup:unix": "pg_dump \"$DATABASE_URL\" > tehilla-backup.sql",
    "worker:payments": "node src/workers/payment.worker.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.56.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  }
}
