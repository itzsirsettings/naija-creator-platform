# Backend environment template.
# Copy to backend/.env and fill in real values, OR set these as Railway
# service variables in the dashboard. NEVER commit real secrets to this file.

# Postgres (Neon) — pooled for the app, unpooled (direct) for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Auth — generate fresh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_64_byte_hex_secret"

ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_DAYS=30

# Payments — use sk_test_ for dev, sk_live_ for production.
PAYSTACK_SECRET_KEY="sk_test_your_paystack_key_here"

FRONTEND_URL="https://tehilla.work"
ALLOWED_ORIGINS="https://tehilla.work"
NODE_ENV="production"
LOG_LEVEL="info"
METRICS_ENABLED=true

# Redis — Railway managed Redis URL (redis.railway.internal only resolves on Railway).
REDIS_URL="redis://default:PASSWORD@redis.railway.internal:6379"
REDIS_REQUIRED=true

REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=20

# KYC field encryption — generate fresh:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KYC_ENCRYPTION_KEY="replace_with_base64_32_byte_key"

# Observability — your Sentry DSN.
SENTRY_DSN="https://PUBLIC_KEY@oORG.ingest.us.sentry.io/PROJECT_ID"
PAYMENT_MOCKS_ENABLED=false

# Email — sign up free at https://resend.com/api-keys
# EMAIL_FROM must be on a domain VERIFIED in your Resend account, otherwise sends
# to real users are rejected. onboarding@resend.dev only delivers to your own
# Resend account email. (Verified domain for this project: contact.tehilla.work)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="Tehilla <no-reply@contact.tehilla.work>"

PORT=5000
