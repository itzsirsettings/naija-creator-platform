# Backend Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Railway:  postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/railway
DATABASE_URL="postgresql://username:password@localhost:5432/tehilla"

# Direct Postgres URL for Prisma migrations. In Supabase, use the direct DB URL here.
DIRECT_URL="postgresql://username:password@localhost:5432/tehilla"

# JWT secret - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_a_64_byte_random_hex_secret_generated_by_the_command_above"

# Auth session settings
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_DAYS=30

# Paystack secret key (from https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY="sk_test_your_paystack_key_here"

# Payment mocks are only for local/demo deployments. Must remain false in production.
PAYMENT_MOCKS_ENABLED=false

# Public frontend URL used in verification and password reset emails.
FRONTEND_URL="http://localhost:5173"

# Optional extra frontend origins for CORS. Use comma-separated origins in production
# for custom domains, Vercel preview domains, or staging frontends.
ALLOWED_ORIGINS=""

# Error reporting
SENTRY_DSN=""

# Transactional email for verification and password resets
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Tehilla <no-reply@tehilla.example>"

# Resend transactional email (preferred transport). When set, overrides SMTP_*.
RESEND_API_KEY=""

# AES-256-GCM key for KYC field encryption (NIN, BVN, CAC number).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED in production. Optional in development (KYC submission will 503).
KYC_ENCRYPTION_KEY=""

# One-time production admin bootstrap. Remove from the host env after running:
# npm run db:seed:admin
ADMIN_EMAIL=""
ADMIN_TEMP_PASSWORD=""

# Runtime
NODE_ENV="development"
LOG_LEVEL="debug"
METRICS_ENABLED=true

# Redis for distributed rate limits, cache, queues, idempotency support, and workers.
# Production should set REDIS_REQUIRED=true.
REDIS_URL=""
REDIS_REQUIRED=false

# Request and throttling controls
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=20

# Server port
PORT=5000
