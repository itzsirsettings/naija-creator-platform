# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/tehilla"
DIRECT_URL="postgresql://username:password@localhost:5432/tehilla"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="dev_only_replace_with_a_64_character_secret_before_launch"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_DAYS=30

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=5000
FRONTEND_URL="http://localhost:5173"
ALLOWED_ORIGINS=""

# ─── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from: https://console.upstash.com
# REST client (cache + auth guards)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# TCP/TLS endpoint for BullMQ workers (ioredis)
REDIS_URL=""
REDIS_REQUIRED=false

# ─── Payments ─────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER="paystack"
PAYSTACK_SECRET_KEY="sk_test_your_paystack_key_here"
FLUTTERWAVE_SECRET_KEY=""
PAYMENT_MOCKS_ENABLED=true

# ─── KYC Encryption ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KYC_ENCRYPTION_KEY=""

# ─── Email ────────────────────────────────────────────────────────────────────
# Option 1: Resend (recommended)
RESEND_API_KEY=""
# Option 2: SMTP
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Tehilla <no-reply@tehilla.example>"

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=""
LOG_LEVEL="debug"
METRICS_ENABLED=true

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=20
REQUEST_TIMEOUT_MS=30000

# ─── Admin Bootstrap (run once, then remove) ──────────────────────────────────
ADMIN_EMAIL=""
ADMIN_TEMP_PASSWORD=""
