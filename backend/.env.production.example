# Railway API and worker production environment.
# Do not commit real values. Set these in Railway project variables.

NODE_ENV=production
PORT=5000

# Supabase Postgres
# Runtime should use the Supabase pooler URL. DIRECT_URL must be migration-capable.
# If your deploy environment has no IPv6, use the Supabase session pooler URL for DIRECT_URL.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Auth
JWT_SECRET=<64-byte-random-hex>
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30

# Public origins
FRONTEND_URL=https://tehilla.work
ALLOWED_ORIGINS=https://tehilla.work

# Redis
REDIS_REQUIRED=true
REDIS_URL=rediss://<railway-redis-host>:<port>

# Payments
PAYSTACK_SECRET_KEY=sk_live_<paystack-live-secret>
PAYMENT_MOCKS_ENABLED=false

# Transactional email
RESEND_API_KEY=re_<resend-production-key>
EMAIL_FROM=Tehilla <no-reply@tehilla.work>

# Observability
SENTRY_DSN=https://<public-key>@sentry.io/<project-id>
METRICS_ENABLED=true
LOG_LEVEL=info

# KYC field encryption: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KYC_ENCRYPTION_KEY=<32-byte-base64-key>

# Request and rate-limit controls
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=20

# One-time admin bootstrap. Remove after running npm run db:seed:admin.
ADMIN_EMAIL=<admin@tehilla.work>
ADMIN_TEMP_PASSWORD=<temporary-password-min-12-chars>
